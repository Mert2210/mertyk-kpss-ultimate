# Azure Cosmos DB (MongoDB API) Bağlantı Dizesi
MONGODB_URI=mongodb://...

# Azure Blob Storage Bağlantı Dizesi
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# JWT Güvenlik Anahtarı (Rastgele uzun bir metin)
JWT_SECRET=super_secret_key_123

# Sunucu Portu (Azure bunu kendisi atayabilir)
PORT=5000
